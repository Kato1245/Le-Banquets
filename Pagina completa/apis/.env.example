# Variables de entorno — Backend (Node.js / Express)
# Copiá este archivo como .env y completá los valores reales

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=le_banquets_1

# MongoDB
MONGO_URI=mongodb://localhost:27017/le_banquets

# Servidor
PORT=3000

# JWT — Usar una clave larga y aleatoria (mínimo 32 caracteres)
# Podés generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_y_largo

# CORS — URL del frontend (sin slash final)
FRONTEND_URL=http://localhost:5173
