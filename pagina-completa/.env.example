# Variables de entorno — Frontend (React + Vite)
# Copiá este archivo como .env y completá los valores reales

# URL base de la API (sin slash final)
VITE_API_URL=http://localhost:3000/api

# Clave pública de Google reCAPTCHA v2 para el formulario de registro
VITE_RECAPTCHA_KEY=tu_site_key_de_recaptcha_aqui
